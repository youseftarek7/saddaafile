        </div>
      </div>
      <button onclick="closeAI()" style="width:34px;height:34px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:50%;color:var(--text-secondary);cursor:pointer;display:flex;align-items:center;justify-content:center;">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <!-- Body -->
    <div style="flex:1;overflow-y:auto;padding:20px;" id="ai-body">
      <!-- Main view -->
      <div id="ai-main-view">
        <p style="text-align:center;color:var(--text-secondary);font-size:0.88rem;margin-bottom:20px;">
          قولي حاسس بإيه وأنا هظبطلك الأكلة! 😉
        </p>
        <div class="mood-grid">
          <button class="mood-btn" onclick="askAI('تصبيرة - محتاج وجبة خفيفة سريعة')">
            <span class="emoji">🍟</span>
            <span class="mood-name">تصبيرة</span>
            <span class="mood-desc">وجبة خفيفة على السريع</span>
          </button>
          <button class="mood-btn" onclick="askAI('حاجة تشبع - عايز وجبة كبيرة مشبعة')">
            <span class="emoji">🍔</span>
            <span class="mood-name">حاجة تشبع</span>
            <span class="mood-desc">وجبة تملى التانك</span>
          </button>
          <button class="mood-btn" onclick="askAI('طعم يبهرك - اقترحلي أكلة مميزة')">
            <span class="emoji">✨</span>
            <span class="mood-name">طعم يبهرك</span>
            <span class="mood-desc">أعلى تقييم واختراعات</span>
          </button>
          <button class="mood-btn" onclick="askAI('أنا جعان جداً - عايز وليمة كبيرة')">
            <span class="emoji">🦁</span>
            <span class="mood-name">جعان جداً</span>
            <span class="mood-desc">عايز وليمة لوحدي</span>
          </button>
        </div>
        <div style="position:relative;margin-top:8px;">
          <input type="text" id="ai-user-input" class="form-input" placeholder="أو اكتب هنا... (مثلاً: عايز كريب فراخ)" 
            onkeypress="if(event.key==='Enter') sendAIMessage()"
            style="padding-left:50px;">
          <button onclick="sendAIMessage()" style="position:absolute;left:8px;top:50%;transform:translateY(-50%);width:36px;height:36px;background:var(--brand-red);border:none;border-radius:8px;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:0.85rem;">
            <i class="fas fa-paper-plane"></i>
          </button>
        </div>
      </div>
      <!-- Results view -->
      <div id="ai-results-view" style="display:none;">
        <div id="ai-message-text" style="text-align:center;color:var(--brand-gold);font-weight:700;font-size:0.95rem;margin-bottom:16px;"></div>
        <div id="ai-products-grid"></div>
        <div style="text-align:center;margin-top:16px;">
          <button onclick="resetAI()" class="btn-secondary" style="font-size:0.85rem;padding:10px 20px;">
            <i class="fas fa-redo-alt"></i> جرب تاني
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ==========================================
     ORDER TRACKING MODAL
     ========================================== -->
<div class="tracking-modal" id="tracking-modal" onclick="handleTrackingBackdrop(event)">
  <div class="tracking-panel">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
      <h2 style="font-weight:700;font-size:1rem;display:flex;align-items:center;gap:8px;">
        <i class="fas fa-map-pin" style="color:var(--brand-red)"></i>
        تتبع الطلب
      </h2>
      <button onclick="closeTracking()" style="width:34px;height:34px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:50%;color:var(--text-secondary);cursor:pointer;display:flex;align-items:center;justify-content:center;">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <!-- Search -->
    <div id="tracking-search" style="display:flex;gap:8px;margin-bottom:20px;">
      <input type="text" id="order-number-input" class="form-input" placeholder="أدخل رقم الطلب" style="flex:1;">
      <button onclick="trackOrder()" class="btn-primary" style="padding:12px 16px;border-radius:10px;">
        <i class="fas fa-search"></i>
      </button>
    </div>
    <!-- Result -->
    <div id="tracking-result"></div>
  </div>
</div>

<!-- ==========================================
     ADMIN PANEL
     ========================================== -->
<div class="admin-panel" id="admin-panel">
  <!-- Admin Header -->
  <div style="padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:#0a0a0a;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;gap:10px;">
      <i class="fas fa-shield-alt" style="color:var(--brand-red);font-size:1.2rem;"></i>
      <span style="font-weight:700;font-size:1rem;">لوحة التحكم</span>
    </div>
    <button onclick="closeAdmin()" style="background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:8px;color:var(--text-secondary);cursor:pointer;padding:8px 12px;font-family:'Cairo',sans-serif;font-size:0.82rem;display:flex;align-items:center;gap:6px;">
      <i class="fas fa-times"></i> إغلاق
    </button>
  </div>
  <!-- Admin Nav -->
  <div class="admin-nav">
    <button class="admin-nav-btn active" onclick="adminTab('orders')" id="admin-tab-orders">
      <i class="fas fa-list-alt"></i> الطلبات
    </button>
    <button class="admin-nav-btn" onclick="adminTab('products')" id="admin-tab-products">
      <i class="fas fa-hamburger"></i> المنتجات
    </button>
    <button class="admin-nav-btn" onclick="adminTab('add-product')" id="admin-tab-add-product">
      <i class="fas fa-plus"></i> إضافة منتج
    </button>
  </div>
  <!-- Admin Body -->
  <div id="admin-body" style="padding:16px 20px;"></div>
</div>

<!-- Hidden admin trigger: click logo 5 times -->
<div id="admin-trigger" onclick="adminTriggerClick()" style="position:fixed;bottom:80px;left:8px;width:28px;height:28px;z-index:50;opacity:0;cursor:pointer;"></div>

<!-- ==========================================
     SCRIPTS
     ========================================== -->
<script src="script.js"></script>
<script>
// Toggle address field
function toggleAddressField() {
  const type = document.querySelector('input[name="orderType"]:checked')?.value;
  const field = document.getElementById('address-field');
  if (field) field.style.display = type === 'delivery' ? 'flex' : 'none';
}
</script>
</body>
</html>