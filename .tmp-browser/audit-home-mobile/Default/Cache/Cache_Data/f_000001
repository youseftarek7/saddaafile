  <link rel="stylesheet" href="style.css">

  <!-- Firebase SDK -->
  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
    import { getFirestore, collection, addDoc, getDocs, getDoc, doc, setDoc, updateDoc, deleteDoc, serverTimestamp, query, orderBy, onSnapshot } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

    // ⚠️ ضع إعدادات Firebase الخاصة بك هنا
    const firebaseConfig = {
      apiKey: "AIzaSyCjie2Psi57Md2oqbeSd4U-Hr5VsVAnNb0",
      authDomain: "saddares.firebaseapp.com",
      projectId: "saddares",
      storageBucket: "saddares.firebasestorage.app",
      messagingSenderId: "287878152677",
      appId: "1:287878152677:web:556b5d7a45e804794bef0c"
    };

    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);

    // جعل Firebase متاح للكود الرئيسي
    window.db = db;
    window.fsCollection = collection;
    window.fsAddDoc = addDoc;
    window.fsGetDocs = getDocs;
    window.fsGetDoc = getDoc;
    window.fsDoc = doc;
    window.fsSetDoc = setDoc;
    window.fsUpdateDoc = updateDoc;
    window.fsDeleteDoc = deleteDoc;
    window.fsServerTimestamp = serverTimestamp;
    window.fsQuery = query;
    window.fsOrderBy = orderBy;
    window.fsOnSnapshot = onSnapshot;
    window.firebaseReady = true;
    document.dispatchEvent(new Event('firebaseReady'));
  </script>
</head>
