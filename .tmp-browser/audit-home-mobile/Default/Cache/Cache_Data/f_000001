    </div>
    <div class="menu-sticky-stack">
    <div class="menu-tools">
      <div class="menu-search-wrap">
        <i class="fas fa-search"></i>
        <input
          type="text"
          id="menu-search-input"
          class="menu-search-input"
          placeholder="ابحث عن أكلة... (مثال: كريب فراخ)"
          oninput="handleMenuSearch(this.value)"
        >
        <button id="menu-search-clear" class="menu-search-clear" onclick="clearMenuSearch()" style="display:none;" aria-label="مسح البحث">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <button class="menu-filter-chip" onclick="clearMenuSearch()">
        <i class="fas fa-layer-group"></i>
        كل الأصناف
      </button>
    </div>
    <!-- كاتيجوريز -->
    <div class="no-scrollbar categories-scroll" id="categories-scroll" style="margin-bottom:16px;"></div>
    </div>
    <!-- عنوان القسم -->
    <div class="section-header" style="margin-bottom:16px;">
      <div class="section-header-line"></div>
      <span class="section-header-title" id="current-cat-title">المنيو</span>
      <div class="section-header-line"></div>
    </div>
    <!-- المنتجات -->
    <div class="products-grid" id="products-grid"></div>
  </section>

</main>

