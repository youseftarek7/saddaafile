<!-- ==========================================
     CART MODAL
     ========================================== -->
<div class="cart-backdrop" id="cart-backdrop" onclick="closeCart()"></div>
<div class="cart-panel" id="cart-panel">
  <div class="cart-header">
    <h2 style="font-weight:700;font-size:1.05rem;display:flex;align-items:center;gap:8px;">
      <i class="fas fa-shopping-bag" style="color:var(--brand-red)"></i> السلة
    </h2>
    <button onclick="closeCart()" style="width:34px;height:34px;background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:50%;color:var(--text-secondary);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;">
      <i class="fas fa-times"></i>
    </button>
  </div>
  <div class="cart-body" id="cart-body">
    <!-- Cart items injected by JS -->
  </div>
  <div class="cart-footer" id="cart-footer" style="display:none;">
    <!-- Customer form -->
    <div id="customer-form-wrap" style="margin-bottom:16px;">
      <h3 style="font-size:0.85rem;font-weight:700;color:var(--brand-gold);margin-bottom:12px;display:flex;align-items:center;gap:6px;">
        <i class="fas fa-user-circle"></i> بيانات الطلب
      </h3>
      <div class="form-group">
        <label class="form-label">الاسم بالكامل</label>
        <input type="text" id="cust-name" class="form-input" placeholder="اكتب اسمك هنا">
      </div>
      <div class="form-group">
        <label class="form-label">رقم الهاتف</label>
        <input type="tel" id="cust-phone" class="form-input" placeholder="01xxxxxxxxx">
      </div>
      <div style="margin-bottom:12px;">
        <label class="form-label" style="margin-bottom:8px;display:block;">طريقة الاستلام</label>
        <div class="order-type-wrap">
          <label class="order-type-label">
            <input type="radio" name="orderType" value="delivery" checked onchange="toggleAddressField()">
            <div class="order-type-card">
              <i class="fas fa-motorcycle"></i>
              <span>دليفري</span>
            </div>
          </label>
          <label class="order-type-label">
            <input type="radio" name="orderType" value="pickup" onchange="toggleAddressField()">
            <div class="order-type-card">
              <i class="fas fa-store"></i>
              <span>استلام</span>
            </div>
          </label>
        </div>
      </div>
      <div id="address-field" class="form-group">
        <label class="form-label">العنوان بالتفصيل</label>
        <textarea id="cust-address" class="form-input" rows="2" placeholder="الشارع، رقم المبنى..."></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">ملاحظة (اختياري)</label>
        <textarea id="order-note" class="form-input" rows="2" placeholder="مثلا: بدون كاتشب..."></textarea>
      </div>
    </div>
    <!-- Total & checkout -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
      <span style="color:var(--text-secondary);font-size:0.9rem;">الإجمالي:</span>
      <span id="cart-total" style="font-weight:700;font-size:1.2rem;color:var(--brand-gold);">0 ج.م</span>
    </div>
    <button onclick="checkout()" class="btn-primary" style="width:100%;justify-content:center;border-radius:12px;">
      <i class="fab fa-whatsapp" style="font-size:1.2rem;"></i>
      إتمام الطلب عبر واتساب
    </button>
  </div>
</div>

<!-- ==========================================
     OPTIONS MODAL
     ========================================== -->
<div class="modal-backdrop" id="options-backdrop" onclick="handleOptionsBackdrop(event)">
  <div class="options-modal" id="options-modal">
    <div class="modal-header">
      <div class="modal-img-container">
        <img id="modal-img" src="" alt="صورة المنتج">
        <div class="modal-img-overlay">
          <h3 id="modal-item-name" style="font-weight:700;font-size:1.05rem;color:#fff;"></h3>
        </div>
        <button onclick="closeOptionsModal()" class="modal-close-btn">
          <i class="fas fa-times"></i>
        </button>
      </div>
    </div>
    <div class="modal-body" id="modal-body">
      <!-- Injected by JS -->
    </div>
    <div class="modal-footer">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <span style="color:var(--text-secondary);font-size:0.88rem;">الإجمالي:</span>
        <span id="modal-total-price" style="font-size:1.3rem;font-weight:700;color:var(--brand-gold);">0 ج.م</span>
      </div>
      <button id="modal-add-btn" onclick="submitOptionOrder()" class="btn-primary" style="width:100%;justify-content:center;border-radius:12px;font-size:1rem;">
        <i class="fas fa-cart-plus"></i>
        إضافة للسلة
      </button>
    </div>
  </div>
</div>

<!-- ==========================================
     AI MODAL
     ========================================== -->
