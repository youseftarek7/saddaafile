        <div style="width:36px;height:36px;background:rgba(230,57,70,0.1);border:1px solid rgba(230,57,70,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center;">
          <i class="fas fa-robot" style="color:var(--brand-red);font-size:1rem;"></i>
        </div>
        <div>
          <div style="font-weight:700;font-size:0.95rem;">مساعد السعادة</div>
          <div style="font-size:0.7rem;color:var(--brand-gold);display:flex;align-items:center;gap:4px;">
            <span style="width:6px;height:6px;background:#4ade80;border-radius:50%;display:inline-block;"></span>
            متاح الآن
